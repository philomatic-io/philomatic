{
  "name": "philomatic",
  "version": "0.0.0",
  "private": true,
  "description": "Headless learning-graph engine (MVP core)",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "philomatic": "src/cli/index.ts"
  },
  "scripts": {
    "philomatic": "tsx src/cli/index.ts",
    "serve": "tsx src/server/ingest.ts",
    "ui:dev": "pnpm --filter philomatic-ui dev",
    "ui:build": "pnpm --filter philomatic-ui build",
    "build:extension": "node scripts/build-extension.mjs",
    "diagram": "tsx scripts/generate-diagram.ts",
    "package:alpha": "node scripts/package-alpha.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "obsidian:build": "pnpm --filter philomatic-obsidian build",
    "obsidian:dev": "pnpm --filter philomatic-obsidian dev",
    "demo:build": "pnpm --filter philomatic-ui demo:build"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.3",
    "sql.js": "^1.14.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/chrome": "^0.2.2",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/sql.js": "^1.4.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
